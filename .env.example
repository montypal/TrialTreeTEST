# ──────────────────────────────────────────────────────────────────────────
# TrialTree environment variables
# Copy this file to `.env` and fill in real values.
# ──────────────────────────────────────────────────────────────────────────

# --- Database ---------------------------------------------------------------
# Local Docker Postgres (see docker-compose.yml) or a hosted provider
# (Supabase / Neon / RDS). Must be a direct, non-pooled connection for Prisma
# migrations; you can use a pooled URL at runtime via DATABASE_URL_POOLED.
DATABASE_URL="postgresql://trialtree:trialtree@localhost:5432/trialtree?schema=public"

# --- AI parser --------------------------------------------------------------
# Choose the parser backend: "openai" or "anthropic". Both are implemented in
# src/lib/ai/parser.ts and return the identical validated action — switching is
# just this env var (+ the matching API key).
AI_PROVIDER="anthropic"

# --- OpenAI backend ---
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-2024-08-06"            # any model that supports structured outputs

# --- Anthropic backend (recommended) ---
ANTHROPIC_API_KEY="sk-ant-..."
# Most capable; for a high-volume classifier you may prefer claude-sonnet-4-6 (cheaper/faster).
ANTHROPIC_MODEL="claude-opus-4-8"

# Confidence gate: actions at/above this auto-apply; below this go to review.
AI_AUTOAPPLY_THRESHOLD="85"

# --- Twilio (inbound SMS) ---------------------------------------------------
# The Auth Token is what Twilio uses to sign the X-Twilio-Signature header.
# (The brief called this TWILIO_WEBHOOK_SECRET; both names are accepted.)
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_WEBHOOK_SECRET="your_twilio_auth_token"   # alias, optional
TWILIO_PHONE_NUMBER="+13105550100"          # the number clinicians text / QR codes target

# Public base URL Twilio calls (used to reconstruct the signed URL behind a proxy).
# e.g. https://trialtree.yourdomain.org   — no trailing slash.
PUBLIC_BASE_URL="http://localhost:3000"

# --- SendGrid Inbound Parse (inbound email) --------------------------------
# Shared secret appended to the Inbound Parse webhook URL as ?token=...
INBOUND_PARSE_SECRET="generate_a_long_random_string"
# Comma-separated list of email domains allowed to mutate the tree.
ALLOWED_EMAIL_DOMAINS="cityofhope.org,mednet.ucla.edu,health.ucsd.edu,hs.uci.edu,med.usc.edu"

# --- App --------------------------------------------------------------------
NEXT_PUBLIC_SMS_NUMBER="+13105550100"       # rendered into kiosk QR codes (client-visible)

# --- Dev tools --------------------------------------------------------------
# /api/dev/simulate and the admin "Dev" panel are auto-enabled in development
# and hard-disabled in production. Set to "true" ONLY to deliberately enable the
# simulator on a deployed instance for a demo (it bypasses webhook auth).
# ENABLE_DEV_SIMULATE="false"
